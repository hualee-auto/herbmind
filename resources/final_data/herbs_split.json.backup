  {
    "id": "rencan",
    "name": "人参",
    "pinyin": "rencan",
    "aliases": [
      "人衔",
      "鬼盖"
    ],
    "category": "补虚药",
    "subCategory": "补气药",
    "nature": "甘，平",
    "flavor": [
      "甘"
    ],
    "meridians": [
      "脾经",
      "肺经"
    ],
    "effects": [
      "大补元气",
      "补肺益脾",
      "生津",
      "安神。【临床应用】1.用于气虚欲脱",
      "脉微细等症。人参功能大补元气",
      "所以常用以挽救气虚欲脱之症。临床上如遇气息短促",
      "汗出肢冷",
      "脉微细",
      "或大量失血引起的虚脱等危急的症候",
      "可单用一味人参煎服",
      "以补气固脱",
      "…… />"
    ],
    "indications": [
      "用于气虚欲脱、脉微细等症。人参功能大补元气，所以常用以挽救气虚欲脱之症。临床上如遇气息短促、汗出肢冷、脉微细，或大量失血引起的虚脱等危急的症候，可单用一味人参煎服，以补气固脱；…… />"
    ],
    "usage": "五分至三钱，用文火另煎，单独服（先饮汁，再食渣），或将参汁加入其它药汁内饮服；如用于急救虚脱，大剂可用五钱至一两，煎汁分数次灌服。如研粉或制成片剂，吞服，每次三分至五分，或三片至正片，每天一次至三次。",
    "contraindications": [
      "实证",
      "热证",
      "不宜与藜芦",
      "五灵脂",
      "皂荚同用"
    ],
    "memoryTip": "人参大补元气，补肺益脾，生津",
    "association": "人参具有大补元气、补肺益脾的作用",
    "keyPoint": "大补元气",
    "similarTo": [],
    "isCommon": true,
    "examFrequency": 3,
    "source": "https://www.zysj.com.cn/lilunshuji/zhongyaoxue/1811.html",
    "images": {
      "plant": "https://www.bing.com/images/search?q=%E4%BA%BA%E5%8F%82+植物",
      "medicinal": "https://www.zyctd.com/search?keyword=%E4%BA%BA%E5%8F%82",
      "slice": "https://www.bing.com/images/search?q=%E4%BA%BA%E5%8F%82+中药饮片"
    },
    "originalName": "人参（附:人参叶、人参芦）"
  },
